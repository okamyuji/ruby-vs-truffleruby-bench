#!/usr/bin/env ruby
# typed: true
# frozen_string_literal: true

require "optparse"
$LOAD_PATH.unshift(File.expand_path("../lib", __dir__))
require "ruby_bench"

options = { smoke: false, output: ENV.fetch("RUBY_BENCH_RESULT_PATH", "results/#{RubyBench::Runtime.id}.json") }

OptionParser
  .new do |o|
    o.banner = "Usage: bin/bench [options]"
    o.on("--smoke", "短時間のスモーク実行") { options[:smoke] = true }
    o.on("-o", "--output PATH", "出力 JSON のパス") { |v| options[:output] = v }
  end
  .parse!

runner = RubyBench::Runner.new(smoke: options[:smoke])
# 起動計測はサブプロセスなので順序非依存。ウォームアップ曲線は JIT が温まる前に取りたいので
# run_all より先に実行する。
runner.run_startup
runner.run_warmup
runner.run_parallelism
runner.run_all

RubyBench::Reporter.new(
  runner.harness.measurements,
  warmup: runner.warmup,
  startup: runner.startup,
  parallelism: runner.parallelism
).dump(options[:output])
puts "wrote #{options[:output]}"
